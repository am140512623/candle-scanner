//@version=6
// =====================================================================
// Bollinger Breakout  ->  Liquidity Grab   (INDICATOR)
// ---------------------------------------------------------------------
// A LONG setup: the SAME liquidity-grab "swallow" as the scanner, with one
// extra gate on the trigger candle -- a Bollinger breakout on that bar:
//
//   1) LIQUIDITY GRAB (bullish "swallow", same engine as every bot):
//        - A GREEN trigger candle whose body covers the prior green
//          candle body(s) and whose LOW runs BELOW their low(s) -- it
//          sweeps the liquidity resting under the recent block, then
//          closes green. Fires on either layout:
//            2-candle: trigger swallows the 1 candle before it.
//            3-candle: trigger swallows the 2-candle block before it.
//
//   2) BOLLINGER BREAKOUT on that same trigger candle:
//        - it OPENS below the UPPER band, and
//        - it CLOSES above the UPPER band
//      i.e. the grab candle punches up THROUGH the top band in one bar.
//
//   ENTRY = a grab whose trigger candle closes above the upper Bollinger
//           band while having opened below it. Twin of scan_bb_grab.py.
// =====================================================================
indicator("Bollinger Breakout → Liquidity Grab", overlay = true,
     max_lines_count = 500, max_labels_count = 500, max_bars_back = 1000)

// ----------------------------- inputs --------------------------------
bbLen  = input.int(20,   "Bollinger length",      minval = 2,   group = "Bollinger Bands")
bbMult = input.float(2.0,"Bollinger StdDev mult", minval = 0.1, group = "Bollinger Bands")

maxWait = input.int(10, "Reclaim: max candles after the opposite candle",
     minval = 1, group = "Reclaim")

drawLevels = input.bool(true, "Draw pattern lines / labels", group = "Display")

// -------------------------- Bollinger Bands --------------------------
basis = ta.sma(close, bbLen)
dev   = bbMult * ta.stdev(close, bbLen)
upper = basis + dev
lower = basis - dev

pU = plot(upper, "Upper", color = color.new(color.red, 0),    linewidth = 1)
pB = plot(basis, "Basis", color = color.new(color.orange, 0), linewidth = 1, style = plot.style_line)
pL = plot(lower, "Lower", color = color.new(color.blue, 0),   linewidth = 1)
fill(pU, pL, color = color.new(color.gray, 92))

// --------------------- liquidity grab (swallow) ----------------------
// Bullish grab: GREEN trigger swallows the prior green candle body(s) and
// sweeps below their low(s). No close/shape rule beyond that.
bool triggerGreen = close > open
float bodyTop     = math.max(open, close)

bool green1   = close[1] > open[1]
float refTop1 = math.max(open[1], close[1])
bool swallow2 = triggerGreen and green1 and bodyTop >= refTop1 and low <= low[1]

bool green2   = close[2] > open[2]
float refTop2 = math.max(open[2], close[2])
bool swallow3 = triggerGreen and green1 and green2 and
     bodyTop >= math.max(refTop1, refTop2) and low <= math.min(low[1], low[2])

bool grab = swallow2 or swallow3

// ----------------------- Bollinger breakout gate ---------------------
// The grab candle must punch UP THROUGH the top band in this one bar:
// open below the upper band, close above it.
bool bbBreakout = open < upper and close > upper

bool signal = grab and bbBreakout

// ============ EXTRA: grab -> opposite candle -> reclaim ==============
// An additional signal on top of the one above (that one still fires as before):
//   1) a gated grab (the `signal` bar), then
//   2) the candle IMMEDIATELY after it is OPPOSITE -- a RED candle. Its OPEN
//      becomes the level to reclaim.
//   3) the FIRST candle to CLOSE above that red candle's OPEN is the signal
//      candle. Only the first one counts; afterwards the setup is spent.
// The reclaim must arrive within `maxWait` candles of the red candle.
var float oppOpen = na
var int   oppBar  = na

// Evaluate the reclaim against the level carried in from earlier bars FIRST, so a
// red candle that arms a new setup can never overwrite one it is reclaiming.
float rcLevel = oppOpen                 // kept for drawing: the state is cleared below
int   rcBar   = oppBar
bool armed    = not na(oppOpen) and bar_index > oppBar and (bar_index - oppBar) <= maxWait
bool reclaim  = armed and close > oppOpen

if reclaim or (not na(oppBar) and bar_index - oppBar >= maxWait)
    oppOpen := na                       // fired, or waited too long -- drop it
    oppBar  := na

// Arm: previous bar was a gated grab and this one is the opposite colour.
if signal[1] and close < open
    oppOpen := open
    oppBar  := bar_index

// --------------------------- drawing ---------------------------------
// Marker code, shared with the scanner's PNGs (see bb_chart.py):
//   SHAPE  ▲ = the UPPER band was touched (this script)   ▼ = the lower band
//   COLOUR white = plain grab            gold = grab → opposite → reclaim
// Both are LONG (BUY) -- the arrow says which BAND, not the trade direction.
plotshape(signal, title = "Buy (upper-band touch grab)", style = shape.triangleup,
     location = location.belowbar, color = color.white, size = size.small, text = "BUY")

plotshape(reclaim, title = "Buy (upper-band touch grab reclaim)", style = shape.triangleup,
     location = location.belowbar, color = #D4A017, size = size.small, text = "RECLAIM")

if reclaim and drawLevels
    // the reclaimed level: the opposite candle's open, run out to the signal bar
    line.new(rcBar, rcLevel, bar_index, rcLevel, xloc = xloc.bar_index,
         color = #D4A017, style = line.style_solid, width = 2)
    label.new(bar_index, high, "RECLAIM ▲", xloc = xloc.bar_index,
         yloc = yloc.abovebar, style = label.style_label_down,
         color = #D4A017, textcolor = color.black, size = size.small)

if signal and drawLevels
    // the grab candle(s) -> the entry
    int grabStart = swallow3 ? bar_index - 2 : bar_index - 1
    line.new(grabStart, low, bar_index, low, xloc = xloc.bar_index,
         color = color.white, style = line.style_dotted, width = 1)
    label.new(bar_index, high, "GRAB ▲ (upper band)", xloc = xloc.bar_index,
         yloc = yloc.abovebar, style = label.style_label_down,
         color = color.white, textcolor = color.black, size = size.small)

// --------------------------- alerts ----------------------------------
alertcondition(signal, "Bollinger Breakout Grab",
     "Liquidity grab closing above the upper Bollinger band: BUY")

alertcondition(reclaim, "Bollinger Breakout Grab → Reclaim",
     "Breakout grab, opposite candle after it, now closed back above that candle's open: BUY")
