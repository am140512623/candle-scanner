//@version=6
// =====================================================================
// RSI Oversold Divergence  ->  Liquidity Grab   (INDICATOR)
// ---------------------------------------------------------------------
// A two-stage LONG setup:
//
//   1) RSI DIVERGENCE (fully oversold):
//        - Price prints a LOWER low between two RSI pivot lows.
//        - RSI prints a HIGHER low over the same two pivots.
//        - BOTH RSI pivot lows sit BELOW 30 (the whole divergence is
//          under the oversold line). If BOTH are under 20 the setup is
//          flagged STRONG and alerts/plots in a different colour.
//
//   2) LIQUIDITY GRAB (bullish "swallow", same engine as the scanner):
//        - A GREEN trigger candle whose body covers the prior green
//          candle body(s) and whose LOW runs BELOW their low(s) -- it
//          sweeps the liquidity resting under the recent block, then
//          closes green. Fires on either layout:
//            2-candle: trigger swallows the 1 candle before it.
//            3-candle: trigger swallows the 2-candle block before it.
//
//   ENTRY = the grab that appears WITHIN a window AFTER a valid
//           oversold divergence. Normal = aqua, Strong (<20) = fuchsia.
// =====================================================================
indicator("RSI Oversold Divergence → Liquidity Grab", overlay = true,
     max_lines_count = 500, max_labels_count = 500, max_bars_back = 1000)

// ----------------------------- inputs --------------------------------
rsiLen      = input.int(14,  "RSI length", minval = 2, group = "RSI divergence")
osLevel     = input.float(30,"Oversold line (whole divergence must be under)", group = "RSI divergence")
strongLevel = input.float(20,"Strong line (both legs under = different colour)", group = "RSI divergence")
pivLb       = input.int(3,   "RSI pivot: bars to the LEFT",  minval = 1, group = "RSI divergence")
pivRb       = input.int(3,   "RSI pivot: bars to the RIGHT", minval = 1, group = "RSI divergence")
minGap      = input.int(3,   "Min bars between the two RSI lows",  minval = 1, group = "RSI divergence")
maxGap      = input.int(60,  "Max bars between the two RSI lows",  minval = 2, group = "RSI divergence")

grabWindow  = input.int(30,  "Max bars from divergence to the grab", minval = 1, group = "Liquidity grab")

drawLevels  = input.bool(true,"Draw pattern lines / labels", group = "Display")

// ------------------------------ RSI ----------------------------------
rsi = ta.rsi(close, rsiLen)

// ------------------- RSI pivot-low bookkeeping -----------------------
// A confirmed RSI pivot low prints pivRb bars back. We keep the PREVIOUS
// pivot so each new one can be compared against it for divergence.
var float prevRsiPL   = na          // RSI value at the previous pivot low
var float prevPricePL = na          // price low at the previous pivot low
var int   prevPLBar   = na          // bar_index of the previous pivot low

// State of the most recent valid oversold divergence (consumed by a grab).
var int   divBar    = na            // bar of the SECOND (confirming) RSI low
var bool  divStrong = false         // both legs under the strong line?

// Coordinates kept only for drawing the divergence line + labels.
var int   d1Bar = na
var float d1Price = na
var float d1Rsi = na
var int   d2Bar = na
var float d2Price = na
var float d2Rsi = na

pl = ta.pivotlow(rsi, pivLb, pivRb)
if not na(pl)
    float curRsi   = pl
    int   curBar   = bar_index - pivRb
    float curPrice = low[pivRb]
    if not na(prevRsiPL)
        int  gap     = curBar - prevPLBar
        bool priceLL = curPrice < prevPricePL          // price lower low
        bool rsiHL   = curRsi   > prevRsiPL            // RSI higher low
        bool bothOs  = curRsi < osLevel and prevRsiPL < osLevel
        bool inGap   = gap >= minGap and gap <= maxGap
        if priceLL and rsiHL and bothOs and inGap
            divBar    := curBar
            divStrong := curRsi < strongLevel and prevRsiPL < strongLevel
            d1Bar   := prevPLBar
            d1Price := prevPricePL
            d1Rsi   := prevRsiPL
            d2Bar   := curBar
            d2Price := curPrice
            d2Rsi   := curRsi
    // roll the "previous pivot" forward
    prevRsiPL   := curRsi
    prevPricePL := curPrice
    prevPLBar   := curBar

// --------------------- liquidity grab (swallow) ----------------------
// Bullish grab: GREEN trigger swallows the prior green candle body(s) and
// sweeps below their low(s). No close/shape rule beyond that.
bool triggerGreen = close > open
float bodyTop     = math.max(open, close)

bool green1      = close[1] > open[1]
float refTop1    = math.max(open[1], close[1])
bool swallow2    = triggerGreen and green1 and bodyTop >= refTop1 and low <= low[1]

bool green2      = close[2] > open[2]
float refTop2    = math.max(open[2], close[2])
bool swallow3    = triggerGreen and green1 and green2 and
     bodyTop >= math.max(refTop1, refTop2) and low <= math.min(low[1], low[2])

bool grab = swallow2 or swallow3

// --------------------------- the signal ------------------------------
// Grab must land AFTER the divergence's second low, inside the window.
bool divActive = not na(divBar) and (bar_index - divBar) <= grabWindow
bool signal       = grab and divActive
bool strongSignal = signal and divStrong
bool normalSignal = signal and not divStrong

// --------------------------- drawing ---------------------------------
plotshape(normalSignal, title = "Buy (osc <30)", style = shape.triangleup,
     location = location.belowbar, color = color.aqua, size = size.small, text = "BUY")
plotshape(strongSignal, title = "Buy STRONG (osc <20)", style = shape.triangleup,
     location = location.belowbar, color = color.fuchsia, size = size.normal, text = "BUY+")

if signal and drawLevels
    color sigCol = strongSignal ? color.fuchsia : color.aqua

    // divergence line across the two PRICE lows (price fell...)
    line.new(d1Bar, d1Price, d2Bar, d2Price, xloc = xloc.bar_index,
         color = color.red, style = line.style_dashed, width = 2)
    // ...while RSI rose: tag both legs with their RSI reading
    label.new(d1Bar, d1Price, "RSI " + str.tostring(d1Rsi, "#.#"),
         xloc = xloc.bar_index, yloc = yloc.belowbar, style = label.style_label_up,
         color = color.new(color.red, 20), textcolor = color.white, size = size.tiny)
    label.new(d2Bar, d2Price, "RSI " + str.tostring(d2Rsi, "#.#"),
         xloc = xloc.bar_index, yloc = yloc.belowbar, style = label.style_label_up,
         color = color.new(color.red, 20), textcolor = color.white, size = size.tiny)

    // the grab candle(s) -> the entry
    int grabStart = swallow3 ? bar_index - 2 : bar_index - 1
    line.new(grabStart, low, bar_index, low, xloc = xloc.bar_index,
         color = sigCol, style = line.style_dotted, width = 1)
    label.new(bar_index, high,
         strongSignal ? "GRAB ▲ (RSI<20)" : "GRAB ▲", xloc = xloc.bar_index,
         yloc = yloc.abovebar, style = label.style_label_down,
         color = color.new(sigCol, 0), textcolor = color.white, size = size.small)

// consume the divergence so it fires once
if signal
    divBar := na

// --------------------------- alerts ----------------------------------
alertcondition(normalSignal, "Oversold Divergence Grab",
     "RSI bullish divergence under 30 → liquidity grab: BUY")
alertcondition(strongSignal, "Oversold Divergence Grab (STRONG <20)",
     "RSI bullish divergence under 20 → liquidity grab: STRONG BUY")
alertcondition(signal, "Oversold Divergence Grab (any)",
     "RSI oversold divergence → liquidity grab: BUY")
